# =============================================================================
# ShiftOps environment configuration
# Copy to .env and fill real values. Never commit .env.
#
# Three deployment targets share this file:
#   1. Local development     (docker-compose up)
#   2. Fly.io production     (set via `fly secrets set ...`)
#   3. Vercel frontend       (set via Vercel dashboard, NEXT_PUBLIC_* only)
#
# Comments below mark which env vars belong where.
# =============================================================================

# --- Core ---
APP_ENV=local                     # local | staging | production
APP_NAME=ShiftOps
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Local: http://localhost:8000
# Fly:   https://shiftops-api.fly.dev   (or your custom domain)
API_PUBLIC_URL=http://localhost:8000
# Comma-separated. On Fly: every frontend origin (Vercel prod, custom domain) + 127.0.0.1 if you open Next by IP.
# Code also allows: *.vercel.app, *.telegram.org (plus web.telegram.org / telegram.org in code), private-network preflight.
# deploy_fly_production.ps1 merges this list with the Vercel URL + localhost so custom domains are not wiped.
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Web (TWA) — set in Vercel project settings ---
WEB_PUBLIC_URL=http://localhost:3000
# API **origin** only; client code appends /api (routes are /api/v1/... on the server)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TG_BOT_USERNAME=ShiftOpsBot

# --- Database ---
# Local docker-compose:
POSTGRES_USER=shiftops
POSTGRES_PASSWORD=shiftops
POSTGRES_DB=shiftops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://shiftops:shiftops@postgres:5432/shiftops
DATABASE_URL_SYNC=postgresql+psycopg://shiftops:shiftops@postgres:5432/shiftops
# Pool sizing — see config/settings.py for rationale. Defaults are tuned for
# Supabase free tier (60 conn ceiling). Bump on Hetzner where we own PG.
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
# If Fly logs show DuplicatePreparedStatementError but DATABASE_URL has no :6543
# and no "pooler" in the host, set true to force asyncpg statement_cache_size=0.
# DB_DISABLE_ASYNCPG_STATEMENT_CACHE=true
#
# Production (Supabase):
#   - Use the *Transaction pooler* (port 6543) for the async runtime URL.
#     Direct connection (5432) is IPv6-only and Fly machines have no IPv6
#     egress on free tier. The pooler is dual-stack.
#   - Use the *Session pooler* (port 5432 of the pooler hostname) for sync
#     migrations (Alembic) — transaction pooler doesn't support all DDL.
#   - URL-encode special chars in the password.
#
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# DATABASE_URL_SYNC=postgresql+psycopg://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Redis ---
# Local: redis://redis:6379/0
# Production (Upstash): use the rediss:// (TLS) URL from the Upstash console.
# Free tier: 10k commands/day, 256MB. Plenty for MVP rate-limit + TaskIQ.
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# 32+ random chars. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-32-chars-min-secret-please
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- Telegram ---
TG_BOT_TOKEN=
TG_BOT_USERNAME=ShiftOpsBot
# 32+ random chars. Telegram echoes this in X-Telegram-Bot-Api-Secret-Token.
TG_WEBHOOK_SECRET=change-me-random-32-chars
TG_WEBHOOK_PATH=/api/v1/telegram/webhook
# Private channel where the bot mirrors every uploaded photo (TG-as-storage).
# Bot must be admin there. Use the numeric chat id (negative for channels).
TG_ARCHIVE_CHAT_ID=

# --- Storage provider ---
STORAGE_PROVIDER=telegram         # telegram | r2

# --- Cloudflare R2 (V2 only, leave blank for MVP) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- Anti-fake ---
ANTIFAKE_PHASH_THRESHOLD=5        # bits of difference; <=5 == suspiciously similar
ANTIFAKE_HISTORY_LOOKBACK=50      # how many previous photos to compare against

# --- Sentry ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Feature flags (MVP defaults) ---
FEATURE_OFFLINE_QUEUE=true
FEATURE_ANALYTICS_DASHBOARD=false
FEATURE_BILLING=false
